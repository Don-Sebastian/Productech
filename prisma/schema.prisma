generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                  String               @id @default(cuid())
  name                String
  location            String
  phone               String?
  email               String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  // Production estimation settings (manager-configurable)
  workingHoursPerDay    Float @default(8)  // Hours hot press runs per day
  numHotPresses         Int   @default(1)  // Number of hot press machines
  pressCapacityPerPress Int   @default(10) // Daylights (boards) per press per cook
  glueAlertThresholdKg  Float @default(1000) // Alert when glue stock drops below this (kg)

  companyProducts     CompanyProduct[]
  customers           Customer[]
  dailyProductionLogs DailyProductionLog[]
  dispatchLoads       DispatchLoad[]
  hotPressSessions    HotPressSession[]
  inventoryItems      InventoryItem[]
  machineLogs         MachineLog[]
  notifications       Notification[]
  orders              Order[]
  orderCustomizations OrderCustomization[]
  timelineEvents      OrderTimelineEvent[]
  plywoodCategories   PlywoodCategory[]
  plywoodSizes        PlywoodSize[]
  plywoodThicknesses  PlywoodThickness[]
  productTypes        ProductType[]
  productionBatches   ProductionBatch[]
  productionLists     ProductionList[]
  rawMaterials        RawMaterial[]
  sections            Section[]
  users               User[]
  productTimings      ProductTiming[]
  machines            Machine[]
  machineAssignments  MachineAssignment[]
  peelingMaterials    PeelingMaterial[]
  peelingSessions     PeelingSession[]
  dryerSessions       DryerSession[]
  finishingLogs       FinishingLog[]
  subDepartments      SubDepartment[]
  shifts              Shift[]
  employees           Employee[]
  attendanceRegisters AttendanceRegister[]
  glueStock           GlueStock?
}

model Section {
  id        String   @id @default(cuid())
  name      String
  slug      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users     User[]   @relation("UserSections")
  machines  Machine[]

  @@unique([companyId, slug])
  @@index([companyId])
}

model User {
  id                     String               @id @default(cuid())
  email                  String               @unique
  password               String
  name                   String
  role                   Role                 @default(OPERATOR)
  phone                  String?
  isActive               Boolean              @default(true)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  companyId              String?
  createdById            String?
  managerApprovedLogs    DailyProductionLog[] @relation("DailyLogManager")
  operatorDailyLogs      DailyProductionLog[] @relation("DailyLogOperator")
  supervisorApprovedLogs DailyProductionLog[] @relation("DailyLogSupervisor")
  dispatchLoadsCreated   DispatchLoad[]       @relation("DispatchLoadCreator")
  dispatchLoadsManaged   DispatchLoad[]       @relation("DispatchLoadManager")
  hotPressSessions       HotPressSession[]
  inventoryLogs          InventoryLog[]
  machineLogs            MachineLog[]
  notifications          Notification[]
  createdOrders          Order[]              @relation("OrderCreator")
  timelineEvents         OrderTimelineEvent[]
  productionBatches      ProductionBatch[]
  productionEntries      ProductionEntry[]
  createdProdLists       ProductionList[]     @relation("ProductionListCreator")
  machineAssignments     MachineAssignment[]
  peelingSessions        PeelingSession[]
  dryerSessions          DryerSession[]
  finishingLogs          FinishingLog[]
  company                Company?             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy              User?                @relation("CreatedUsers", fields: [createdById], references: [id])
  createdUsers           User[]               @relation("CreatedUsers")
  sections               Section[]            @relation("UserSections")
  supervisorRegisters    AttendanceRegister[] @relation("SupervisorRegister")
  managerRegisters       AttendanceRegister[] @relation("ManagerRegister")
  wageAdjustments        WageAdjustmentLog[]
  subDepartmentAssignments SubDepartmentAssignment[]

  @@index([companyId])
  @@index([createdById])
  @@index([role])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@unique([companyId, name, phone])
  @@index([companyId])
}

model PlywoodCategory {
  id                String               @id @default(cuid())
  name              String
  isActive          Boolean              @default(true)
  sortOrder         Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  companyId         String
  companyProducts   CompanyProduct[]
  dispatchLoadItems DispatchLoadItem[]
  orderItems        OrderItem[]
  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pressEntries      PressEntry[]
  productionItems   ProductionListItem[]
  productTimings    ProductTiming[]
  finishingEntries  FinishingEntry[]

  @@index([companyId])
}

model PlywoodThickness {
  id                String               @id @default(cuid())
  value             Float
  unit              String               @default("mm")
  isActive          Boolean              @default(true)
  sortOrder         Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  companyId         String
  companyProducts   CompanyProduct[]
  dispatchLoadItems DispatchLoadItem[]
  orderItems        OrderItem[]
  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pressEntries      PressEntry[]
  productionItems   ProductionListItem[]
  productTimings    ProductTiming[]
  finishingEntries  FinishingEntry[]

  @@index([companyId])
}

model ProductTiming {
  id                String           @id @default(cuid())
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId        String
  category          PlywoodCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  thicknessId       String
  thickness         PlywoodThickness @relation(fields: [thicknessId], references: [id], onDelete: Cascade)
  cookingTime       Float            @default(0)
  coolingTime       Float            @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([companyId, categoryId, thicknessId])
  @@index([companyId])
}

model PlywoodSize {
  id                String               @id @default(cuid())
  label             String
  length            Float
  width             Float
  sqft              Float                @default(0)
  isActive          Boolean              @default(true)
  sortOrder         Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  companyId         String
  companyProducts   CompanyProduct[]
  dispatchLoadItems DispatchLoadItem[]
  orderItems        OrderItem[]
  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pressEntries      PressEntry[]
  productionItems   ProductionListItem[]
  finishingEntries  FinishingEntry[]

  @@index([companyId])
}

model CompanyProduct {
  id                String            @id @default(cuid())
  openingStock      Int               @default(0)
  currentStock      Int               @default(0)
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  companyId         String
  categoryId        String
  thicknessId       String
  sizeId            String
  category          PlywoodCategory   @relation(fields: [categoryId], references: [id])
  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  size              PlywoodSize       @relation(fields: [sizeId], references: [id])
  thickness         PlywoodThickness  @relation(fields: [thicknessId], references: [id])
  productionEntries ProductionEntry[]

  @@unique([companyId, categoryId, thicknessId, sizeId])
  @@index([companyId])
}

model ProductionEntry {
  id                   String              @id @default(cuid())
  quantity             Int
  notes                String?
  createdAt            DateTime            @default(now())
  productId            String
  operatorId           String
  dailyLogId           String?
  productionListItemId String?
  dailyLog             DailyProductionLog? @relation(fields: [dailyLogId], references: [id])
  operator             User                @relation(fields: [operatorId], references: [id])
  product              CompanyProduct      @relation(fields: [productId], references: [id])
  productionListItem   ProductionListItem? @relation(fields: [productionListItemId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([operatorId])
  @@index([dailyLogId])
  @@index([productionListItemId])
}

model DailyProductionLog {
  id                     String            @id @default(cuid())
  date                   DateTime
  status                 ApprovalStatus    @default(PENDING)
  notes                  String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  companyId              String
  operatorId             String
  supervisorApprovedById String?
  supervisorApprovedAt   DateTime?
  supervisorNotes        String?
  managerApprovedById    String?
  managerApprovedAt      DateTime?
  managerNotes           String?
  company                Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  managerApprovedBy      User?             @relation("DailyLogManager", fields: [managerApprovedById], references: [id])
  operator               User              @relation("DailyLogOperator", fields: [operatorId], references: [id])
  supervisorApprovedBy   User?             @relation("DailyLogSupervisor", fields: [supervisorApprovedById], references: [id])
  entries                ProductionEntry[]

  @@unique([companyId, operatorId, date])
  @@index([companyId])
  @@index([operatorId])
  @@index([status])
}

model HotPressSession {
  id                          String         @id @default(cuid())
  status                      HotPressStatus @default(RUNNING)
  startTime                   DateTime       @default(now())
  stopTime                    DateTime?
  numDaylights                Int            @default(10)
  shiftDate                   DateTime
  currentCategoryId           String?
  currentThicknessId          String?
  currentSizeId               String?
  approvalStatus              ApprovalStatus @default(PENDING)
  operatorApprovedAt          DateTime?
  supervisorApprovedAt        DateTime?
  managerApprovedAt           DateTime?
  supervisorId                String?
  managerId                   String?
  rejectionNote               String?
  companyId                   String
  operatorId                  String
  machineId                   String?
  currentProductionListItemId String?
  glueEntries                 GlueEntry[]
  company                     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  machine                     Machine?       @relation(fields: [machineId], references: [id])
  operator                    User           @relation(fields: [operatorId], references: [id])
  pauseEvents                 PauseEvent[]
  entries                     PressEntry[]

  @@index([companyId])
  @@index([operatorId])
  @@index([shiftDate])
  @@index([approvalStatus])
}

model PressEntry {
  id                   String              @id @default(cuid())
  type                 PressEntryType      @default(COOK)
  loadTime             DateTime?
  unloadTime           DateTime?
  quantity             Int                 @default(10)
  notes                String?
  createdAt            DateTime            @default(now())
  categoryId           String
  thicknessId          String
  sizeId               String
  sessionId            String
  productionListItemId String?
  category             PlywoodCategory     @relation(fields: [categoryId], references: [id])
  productionListItem   ProductionListItem? @relation(fields: [productionListItemId], references: [id], onDelete: SetNull)
  session              HotPressSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  size                 PlywoodSize         @relation(fields: [sizeId], references: [id])
  thickness            PlywoodThickness    @relation(fields: [thicknessId], references: [id])

  @@index([sessionId])
  @@index([productionListItemId])
}

model GlueEntry {
  id        String          @id @default(cuid())
  time      DateTime        @default(now())
  barrels   Float           @default(1)
  notes     String?
  sessionId String
  session   HotPressSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model PauseEvent {
  id        String          @id @default(cuid())
  type      String
  startTime DateTime        @default(now())
  endTime   DateTime?
  notes     String?
  sessionId String
  session   HotPressSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Order {
  id              String               @id @default(cuid())
  orderNumber     String
  status          OrderStatus          @default(PENDING)
  notes           String?
  dueDate         DateTime?
  estimatedDispatchDate DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  companyId       String
  createdById     String
  customerId      String?
  priority        Int                  @default(3)
  dispatchLoads   DispatchLoad[]
  notifications   Notification[]
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy       User                 @relation("OrderCreator", fields: [createdById], references: [id])
  customer        Customer?            @relation(fields: [customerId], references: [id])
  items           OrderItem[]
  timelineEvents  OrderTimelineEvent[]
  productionLists ProductionList[]

  @@index([companyId])
  @@index([createdById])
  @@index([customerId])
  @@index([status])
  @@index([companyId, status])
}

model OrderCustomization {
  id         String      @id @default(cuid())
  name       String
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  companyId  String
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orderItems OrderItem[] @relation("OrderItemCustomizations")

  @@unique([companyId, name])
  @@index([companyId])
}

model OrderItem {
  id             String               @id @default(cuid())
  quantity       Int
  layers         Int?
  brandSeal      Boolean              @default(false)
  varnish        Boolean              @default(false)
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  orderId        String
  categoryId     String
  thicknessId    String
  sizeId         String
  category       PlywoodCategory      @relation(fields: [categoryId], references: [id])
  order          Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  size           PlywoodSize          @relation(fields: [sizeId], references: [id])
  thickness      PlywoodThickness     @relation(fields: [thicknessId], references: [id])
  customizations OrderCustomization[] @relation("OrderItemCustomizations")

  @@index([orderId])
}

model OrderTimelineEvent {
  id        String   @id @default(cuid())
  action    String
  details   String?
  createdAt DateTime @default(now())
  companyId String
  orderId   String
  userId    String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([orderId])
  @@index([userId])
}

model DispatchLoad {
  id          String             @id @default(cuid())
  loadNumber  String
  status      DispatchStatus     @default(SUPERVISOR_SUBMITTED)
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  companyId   String
  orderId     String
  createdById String
  managerId   String?
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User               @relation("DispatchLoadCreator", fields: [createdById], references: [id])
  manager     User?              @relation("DispatchLoadManager", fields: [managerId], references: [id])
  order       Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items       DispatchLoadItem[]

  @@index([companyId])
  @@index([orderId])
  @@index([createdById])
  @@index([status])
  @@index([companyId, orderId])
}

model DispatchLoadItem {
  id             String           @id @default(cuid())
  quantity       Int
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  dispatchLoadId String
  categoryId     String
  thicknessId    String
  sizeId         String
  category       PlywoodCategory  @relation(fields: [categoryId], references: [id])
  dispatchLoad   DispatchLoad     @relation(fields: [dispatchLoadId], references: [id], onDelete: Cascade)
  size           PlywoodSize      @relation(fields: [sizeId], references: [id])
  thickness      PlywoodThickness @relation(fields: [thicknessId], references: [id])

  @@index([dispatchLoadId])
}

model ProductionList {
  id            String               @id @default(cuid())
  listNumber    String
  status        ProductionStatus     @default(PLANNED)
  notes         String?
  estimatedProductionMinutes Int?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  companyId     String
  orderId       String?
  createdById   String
  priority      Int                  @default(3)
  notifications Notification[]
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy     User                 @relation("ProductionListCreator", fields: [createdById], references: [id])
  order         Order?               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items         ProductionListItem[]

  @@index([companyId])
  @@index([orderId])
}

model ProductionListItem {
  id                String            @id @default(cuid())
  quantity          Int
  layers            Int?
  brandSeal         Boolean           @default(false)
  varnish           Boolean           @default(false)
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  productionListId  String
  categoryId        String
  thicknessId       String
  sizeId            String
  producedQuantity  Int               @default(0)
  pressEntries      PressEntry[]
  productionEntries ProductionEntry[]
  category          PlywoodCategory   @relation(fields: [categoryId], references: [id])
  productionList    ProductionList    @relation(fields: [productionListId], references: [id], onDelete: Cascade)
  size              PlywoodSize       @relation(fields: [sizeId], references: [id])
  thickness         PlywoodThickness  @relation(fields: [thicknessId], references: [id])

  @@index([productionListId])
}

model Notification {
  id               String          @id @default(cuid())
  type             String
  title            String
  message          String
  isRead           Boolean         @default(false) // Left for legacy purposes, but readByUsers is used for targeted roles
  readByUsers      String[]
  targetRole       String?
  createdAt        DateTime        @default(now())
  companyId        String
  userId           String?
  orderId          String?
  productionListId String?
  priority         Int             @default(3)
  company          Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  order            Order?          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productionList   ProductionList? @relation(fields: [productionListId], references: [id], onDelete: Cascade)
  user             User?           @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([isRead])
  @@index([companyId, targetRole])
  @@index([companyId, userId])
}

model ProductType {
  id                String            @id @default(cuid())
  name              String
  thickness         Float
  description       String?
  standardSize      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  companyId         String
  inventoryItems    InventoryItem[]
  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productionBatches ProductionBatch[]

  @@index([companyId])
}

model RawMaterial {
  id             String          @id @default(cuid())
  name           String
  unit           String
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  companyId      String
  batchMaterials BatchMaterial[]
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model ProductionBatch {
  id             String          @id @default(cuid())
  batchNumber    String
  quantity       Int
  status         BatchStatus     @default(INITIATED)
  startDate      DateTime
  completionDate DateTime?
  defectiveUnits Int             @default(0)
  notes          String?
  section        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  companyId      String
  productTypeId  String
  assignedToId   String
  batchMaterials BatchMaterial[]
  assignedTo     User            @relation(fields: [assignedToId], references: [id])
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productType    ProductType     @relation(fields: [productTypeId], references: [id])

  @@index([companyId])
  @@index([productTypeId])
  @@index([assignedToId])
}

model BatchMaterial {
  id         String          @id @default(cuid())
  quantity   Float
  createdAt  DateTime        @default(now())
  batchId    String
  materialId String
  batch      ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  material   RawMaterial     @relation(fields: [materialId], references: [id])

  @@index([batchId])
  @@index([materialId])
}

model InventoryItem {
  id               String         @id @default(cuid())
  quantity         Int
  minimumThreshold Int
  location         String?
  lastRestocked    DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  companyId        String
  productTypeId    String
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productType      ProductType    @relation(fields: [productTypeId], references: [id])
  inventoryLogs    InventoryLog[]

  @@unique([companyId, productTypeId])
  @@index([companyId])
  @@index([productTypeId])
}

model InventoryLog {
  id              String        @id @default(cuid())
  quantity        Int
  type            InventoryType
  reason          String?
  timestamp       DateTime      @default(now())
  inventoryItemId String
  loggedById      String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  loggedBy        User          @relation(fields: [loggedById], references: [id])

  @@index([inventoryItemId])
  @@index([loggedById])
}

model MachineLog {
  id          String        @id @default(cuid())
  machineName String
  action      MachineAction
  timestamp   DateTime      @default(now())
  notes       String?
  section     String?
  shiftDate   DateTime
  createdAt   DateTime      @default(now())
  companyId   String
  operatorId  String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  operator    User          @relation(fields: [operatorId], references: [id])

  @@index([companyId])
  @@index([operatorId])
  @@index([shiftDate])
}

model Machine {
  id               String              @id @default(cuid())
  name             String              // e.g. "HP-1", "Dryer A"
  code             String              // short code for logs
  isActive         Boolean             @default(true)
  sortOrder        Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  companyId        String
  sectionId        String

  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  section          Section             @relation(fields: [sectionId], references: [id])
  assignments      MachineAssignment[]
  hotPressSessions HotPressSession[]
  subDepartments   SubDepartment[]
  shifts           Shift[]
  employees        Employee[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([sectionId])
}

model MachineAssignment {
  id         String    @id @default(cuid())
  role       String    // "OPERATOR" or "SUPERVISOR"
  assignedAt DateTime  @default(now())
  removedAt  DateTime? // null = currently active
  companyId  String
  machineId  String
  userId     String

  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  machine    Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@index([machineId])
  @@index([userId])
  @@index([companyId])
}

enum Role {
  ADMIN
  OWNER
  MANAGER
  SUPERVISOR
  OPERATOR
}

enum ApprovalStatus {
  PENDING
  SUBMITTED
  SUPERVISOR_APPROVED
  MANAGER_APPROVED
  REJECTED
}

enum HotPressStatus {
  RUNNING
  PAUSED
  MAINTENANCE
  STOPPED
}

enum PressEntryType {
  COOK
  REPRESS
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  COMPLETED
  CANCELLED
  SENT_TO_SUPERVISOR
  TO_PRODUCTION_GENERATED
  PRODUCTION_COMPLETED
  READY_FOR_DISPATCH
  DISPATCHED
}

enum DispatchStatus {
  SUPERVISOR_SUBMITTED
  MANAGER_CONFIRMED
  DISPATCHED
}

enum ProductionStatus {
  PLANNED
  PEELING
  DRYING
  PRESSING
  FINISHING
  COMPLETED
}

enum BatchStatus {
  INITIATED
  IN_PROGRESS
  COMPLETED
  QUALITY_CHECK
  FAILED
}

enum InventoryType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
  DAMAGE
}

enum MachineAction {
  START
  STOP
  PAUSE
  RESUME
  MAINTENANCE
  BREAKDOWN
}

enum MachineSessionStatus {
  RUNNING
  PAUSED
  MAINTENANCE
  STOPPED
}

// ==================== PEELING SECTION ====================

model PeelingMaterial {
  id              String         @id @default(cuid())
  treeType        String         // e.g. "Rubber", "Mango", "Silverrock"
  veneerThickness Float          // e.g. 1.4, 1.9 (mm)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries         PeelingEntry[]

  @@unique([companyId, treeType, veneerThickness])
  @@index([companyId])
}

model PeelingSession {
  id          String               @id @default(cuid())
  status      MachineSessionStatus @default(RUNNING)
  startTime   DateTime             @default(now())
  stopTime    DateTime?
  shiftDate   DateTime
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  operatorId  String
  companyId   String
  machineId   String?

  operator    User                 @relation(fields: [operatorId], references: [id])
  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries     PeelingEntry[]
  pauseEvents PeelingPauseEvent[]

  @@index([operatorId])
  @@index([companyId])
  @@index([shiftDate])
}

model PeelingEntry {
  id                String          @id @default(cuid())
  quantity          Int             @default(0)  // veneer sheets peeled
  logCount          Int             @default(0)  // wood logs consumed
  notes             String?
  timestamp         DateTime        @default(now())
  sessionId         String
  peelingMaterialId String

  session           PeelingSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  peelingMaterial   PeelingMaterial @relation(fields: [peelingMaterialId], references: [id])

  @@index([sessionId])
}

model PeelingPauseEvent {
  id        String         @id @default(cuid())
  type      String         @default("PAUSE") // PAUSE or MAINTENANCE
  startTime DateTime       @default(now())
  endTime   DateTime?
  notes     String?
  sessionId String
  session   PeelingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ==================== DRYER SECTION ====================

model DryerSession {
  id                       String               @id @default(cuid())
  status                   MachineSessionStatus @default(RUNNING)
  startTime                DateTime             @default(now())
  stopTime                 DateTime?
  shiftDate                DateTime
  autoCheckEnabled         Boolean              @default(false)
  autoCheckIntervalMinutes Int                  @default(30)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  operatorId               String
  companyId                String
  machineId                String?

  operator    User          @relation(fields: [operatorId], references: [id])
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  batches     DryerBatch[]
  checks      DryerCheck[]
  pauseEvents DryerPauseEvent[]

  @@index([operatorId])
  @@index([companyId])
  @@index([shiftDate])
}

model DryerBatch {
  id              String       @id @default(cuid())
  veneerThickness Float        // mm
  loadTime        DateTime     @default(now())
  unloadTime      DateTime?
  quantity        Int          @default(0)
  notes           String?
  sessionId       String
  session         DryerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model DryerCheck {
  id         String       @id @default(cuid())
  beltSpeed  Float        // belt speed reading
  dryerTemp  Float        // dryer temperature
  boilerTemp Float        // oil boiler temperature
  timestamp  DateTime     @default(now())
  notes      String?
  sessionId  String
  session    DryerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model DryerPauseEvent {
  id        String       @id @default(cuid())
  type      String       @default("PAUSE")
  startTime DateTime     @default(now())
  endTime   DateTime?
  notes     String?
  sessionId String
  session   DryerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ==================== FINISHING SECTION ====================

model FinishingLog {
  id         String           @id @default(cuid())
  shiftDate  DateTime
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  operatorId String
  companyId  String

  operator   User             @relation(fields: [operatorId], references: [id])
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries    FinishingEntry[]

  @@unique([operatorId, shiftDate])
  @@index([companyId])
  @@index([shiftDate])
}

model FinishingEntry {
  id             String          @id @default(cuid())
  quantity       Int             // sheets finished
  notes          String?
  timestamp      DateTime        @default(now())
  categoryId     String
  thicknessId    String
  sizeId         String
  finishingLogId String

  category       PlywoodCategory  @relation(fields: [categoryId], references: [id])
  thickness      PlywoodThickness @relation(fields: [thicknessId], references: [id])
  size           PlywoodSize      @relation(fields: [sizeId], references: [id])
  finishingLog   FinishingLog     @relation(fields: [finishingLogId], references: [id], onDelete: Cascade)

  @@index([finishingLogId])
}

// ==================== ATTENDANCE & HR ====================

model SubDepartment {
  id        String     @id @default(cuid())
  name      String     // e.g., "Glue Mixer", "Assembly"
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  companyId String
  machineId String?

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  machine   Machine?   @relation(fields: [machineId], references: [id], onDelete: SetNull)
  employees Employee[]
  shifts    Shift[]
  supervisorAssignments SubDepartmentAssignment[]

  @@index([companyId])
  @@index([machineId])
}

model SubDepartmentAssignment {
  id              String        @id @default(cuid())
  userId          String
  subDepartmentId String
  createdAt       DateTime      @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subDepartment SubDepartment @relation(fields: [subDepartmentId], references: [id], onDelete: Cascade)

  @@unique([userId, subDepartmentId])
  @@index([userId])
  @@index([subDepartmentId])
}

model Shift {
  id          String               @id @default(cuid())
  name        String               // e.g., "Morning", "Night"
  startTime   String               // "08:00"
  endTime     String               // "16:00"
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  companyId   String
  machineId   String?
  subDepartmentId String?

  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  machine       Machine?             @relation(fields: [machineId], references: [id], onDelete: Cascade)
  subDepartment SubDepartment?       @relation(fields: [subDepartmentId], references: [id], onDelete: Cascade)
  registers     AttendanceRegister[]

  @@index([companyId])
  @@index([machineId])
}

enum WageType {
  DAILY
  WEEKLY
  MONTHLY
}

model Employee {
  id                 String              @id @default(cuid())
  name               String
  phone              String?
  photoData          String?             @db.Text
  wageType           WageType            @default(DAILY)
  wageAmount         Float               @default(0)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  companyId          String
  machineId          String?
  subDepartmentId    String?
  wageLastAdjustedBy String?
  wageLastAdjustedAt DateTime?

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  machine            Machine?            @relation(fields: [machineId], references: [id], onDelete: SetNull)
  subDepartment      SubDepartment?      @relation(fields: [subDepartmentId], references: [id], onDelete: SetNull)
  attendanceEntries  AttendanceEntry[]
  wageLogs           WageAdjustmentLog[]

  @@index([companyId])
  @@index([machineId])
  @@index([subDepartmentId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
}

enum RegisterStatus {
  PENDING
  APPROVED
  REJECTED
}

model AttendanceRegister {
  id           String            @id @default(cuid())
  date         DateTime
  status       RegisterStatus    @default(PENDING)
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  companyId    String
  shiftId      String
  supervisorId String
  managerId    String?

  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shift        Shift             @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  supervisor   User              @relation("SupervisorRegister", fields: [supervisorId], references: [id])
  manager      User?             @relation("ManagerRegister", fields: [managerId], references: [id])
  entries      AttendanceEntry[]

  @@unique([shiftId, date, supervisorId])
  @@index([companyId])
  @@index([shiftId])
  @@index([supervisorId])
  @@index([companyId, date])
}

model AttendanceEntry {
  id            String             @id @default(cuid())
  status        AttendanceStatus   @default(PRESENT)
  overtimeHours Float              @default(0)
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  registerId    String
  employeeId    String

  register      AttendanceRegister @relation(fields: [registerId], references: [id], onDelete: Cascade)
  employee      Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([registerId, employeeId])
  @@index([registerId])
  @@index([employeeId])
}

model WageAdjustmentLog {
  id           String    @id @default(cuid())
  beforeAmount Float
  afterAmount  Float
  wageType     WageType
  reason       String?
  timestamp    DateTime  @default(now())
  employeeId   String
  changedById  String

  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  changedBy    User      @relation(fields: [changedById], references: [id])

  @@index([employeeId])
  @@index([changedById])
}

// ==================== GLUE STOCK TRACKING ====================

model GlueStock {
  id        String        @id @default(cuid())
  currentKg Float         @default(0)
  openingKg Float         @default(0)
  updatedAt DateTime      @updatedAt
  companyId String        @unique
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  logs      GlueStockLog[]
}

model GlueStockLog {
  id         String   @id @default(cuid())
  type       String   // "OPENING", "ADD", "DEDUCTION", "ADJUSTMENT"
  quantityKg Float    // positive = added, negative = deducted
  balanceKg  Float    // stock after this entry
  notes      String?
  createdAt  DateTime @default(now())
  glueStockId String
  userId     String?  // who triggered this
  glueStock  GlueStock @relation(fields: [glueStockId], references: [id], onDelete: Cascade)

  @@index([glueStockId])
}

model demo {
  id String @id @default(uuid()) @db.Text
  name String @default("demo") @db.Text
}
